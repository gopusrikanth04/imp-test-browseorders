_schema-version: "3.2"
ID: sapuidemoorderbrowser-dev

extends: sapuidemoorderbrowser

resources:

  - name: sapuidemoorderbrowser-destination-service
    parameters:
      service-name: sapuidemoorderbrowser-destination-service-dev

  - name: sapuidemoorderbrowser-uaa
    parameters:
      service-name: sapuidemoorderbrowser-xsuaa-service-dev
      config:
        xsappname: sapuidemoorderbrowser-dev

  - name: sapuidemoorderbrowser-repo-host
    parameters:
      service-name: sapuidemoorderbrowser-html5-service-dev

modules:
  - name: sapuidemoorderbrowser-destination-content
    parameters:
      content:
        instance:
          destinations:
            - Name: sapuidemoorderbrowser_html_repo_host
              ServiceInstanceName: sapuidemoorderbrowser-html5-service-dev
              ServiceKeyName: sapuidemoorderbrowser-repo-host-key
              sap.cloud.service: sapuidemoorderbrowser
            - Authentication: OAuth2UserTokenExchange
              Name: sapuidemoorderbrowser_uaa
              ServiceInstanceName: sapuidemoorderbrowser-xsuaa-service-dev
              ServiceKeyName: sapuidemoorderbrowser-uaa-key
              sap.cloud.service: sapuidemoorderbrowser