{
  "name": "orderbrowser",
  "version": "0.0.1",
  "description": "Master-detail app for browsing orders.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33",
    "cross-var": "^1.1.0",
    "eslint": "^10",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5",
    "ui5-task-zipper": "^3.4.x"
  },
  "scripts": {
    "start": "fiori run --open \"test/flp.html#app-preview\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"test/flp.html#app-preview\"",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "lint": "eslint ./",
    "deploy": "fiori cfDeploy",
    "deploy-config": "fiori add deploy-config",
    "start-noflp": "fiori run --open \"/index.html?sap-ui-xx-viewCache=false\"",
    "int-test": "fiori run --open \"test/testsuite.qunit.html\"",
    "start-variants-management": "fiori run --open \"/preview.html#app-preview\"",
    "unit-test": "fiori run --open \"test/Test.qunit.html\"",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "undeploy": "cf undeploy sapuidemoorderbrowser --delete-services --delete-service-keys --delete-service-brokers",
    "build:mta": "mbt build",
    "deploy:cf": "cross-var cf deploy mta_archives/sapuidemoorderbrowser_$npm_package_version.mtar",
    "deploy:cf-dev": "cross-var cf deploy mta_archives/sapuidemoorderbrowser_$npm_package_version.mtar -e mtaext/dev.mtaext",
    "deploy:cf-qa": "cross-var cf deploy mta_archives/sapuidemoorderbrowser_$npm_package_version.mtar -e mtaext/qa.mtaext",
    "deploy:cf-prod": "cross-var cf deploy mta_archives/sapuidemoorderbrowser_$npm_package_version.mtar -e mtaext/prod.mtaext"
  },
  "sapuxLayer": "CUSTOMER_BASE"
}
